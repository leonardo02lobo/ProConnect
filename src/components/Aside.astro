---
import TarjetaEmpresa from "../components/TarjetaEmpresa.astro"
---

<aside class="col-span-1 mt-20">
    <div class="flex flex-col p-6">
        <section class="p-4 rounded-lg mb-4">
            <span class="font-bold ">Empresas a Seguir</span>
            <div class="bg-white shadow-lg border border-gray-200 rounded-lg">
                <TarjetaEmpresa NombreEmpresa="Amazon" descripcion="4 Personas que conocen la siguen" />
                <TarjetaEmpresa NombreEmpresa="Google" descripcion="1 Personas que conocen la siguen" />
            </div>
        </section>
        <section class="p-4 rounded-lg mb-4">
            <span class="font-bold ">Amigos a Seguir</span>
            <div class="bg-white shadow-lg border border-gray-200 rounded-lg">
                <TarjetaEmpresa NombreEmpresa="Tesla" descripcion="4 Personas que conocen la siguen" />
                <TarjetaEmpresa NombreEmpresa="SpaceX" descripcion="24 Personas que conocen la siguen" />
            </div>
        </section>
    </div>
</aside>